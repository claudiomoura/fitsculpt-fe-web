# Frontend runtime configuration (example values only)
# Copy to .env.local for local development.
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_SUPPORT_URL=https://example.com/support
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development

# Deprecated frontend alias retained for backwards compatibility in older docs/scripts.
# Prefer BACKEND_URL (and NEXT_PUBLIC_BACKEND_URL when browser access is needed).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# PostHog Analytics (optional - leave empty to disable)
# Get your API key from https://app.posthog.com/settings/project
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Backend-only production contract (documented values, never commit real secrets)
# DATABASE_URL=
# DIRECT_URL=
# JWT_SECRET=
# COOKIE_SECRET=
# CORS_ORIGIN=http://localhost:3000
# APP_BASE_URL=http://localhost:3000
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=

# Repository-level automation only
# Use this file as a template for repo-root `.env.local`.
# Do not put app runtime secrets here.

# Linear automation
LINEAR_API_KEY=

# Notion HQ automation
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# App runtime envs live in:
# - apps/api/.env.example
# - apps/api/.env.local.example
# - apps/web/.env.example
# See docs/env-strategy.md for the monorepo rules.

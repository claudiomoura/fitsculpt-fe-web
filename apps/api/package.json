{
  "name": "fitsculpt-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/kill-port.mjs",
    "dev": "tsx watch src/index.ts",
    "build:clean": "node scripts/clean-dist.mjs",
    "build:compile": "tsc -p tsconfig.json",
    "build": "npm run build:clean && npm run build:compile",
    "build:repro": "node scripts/verify-dist-rebuild.mjs",
    "start": "node dist/index.js",
    "start:prod": "npm run db:deploy && npm run start",
    "db:deploy": "node scripts/prisma-runner.mjs migrate deploy --schema prisma/schema.prisma",
    "db:migrate": "npm run db:deploy",
    "db:doctor": "node scripts/prisma-runner.mjs doctor",
    "db:repair": "node scripts/prisma-runner.mjs repair",
    "db:baseline:init": "node scripts/db-baseline-init.mjs",
    "db:reset": "node scripts/prisma-runner.mjs reset:safe --force --skip-seed --schema prisma/schema.prisma",
    "db:generate": "prisma generate",
    "db:push:emergency": "prisma db push",
    "db:push:ci": "CI=true node scripts/prisma-runner.mjs db push --force-reset --accept-data-loss --schema prisma/schema.prisma && npm run db:generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "repair:user-columns": "tsx scripts/repair-user-columns.ts",
    "repair:profile-metrics": "tsx scripts/repair-corrupt-profile-metrics.ts",
    "test": "node scripts/run-tests.mjs",
    "verify-email": "tsx scripts/verify-email.ts",
    "db:seed": "prisma db seed",
    "db:bootstrap": "node scripts/db-bootstrap.mjs",
    "db:migrate:render": "node scripts/prisma-runner.mjs migrate deploy",
    "db:seed:safe": "node scripts/prisma-runner.mjs seed:safe",
    "db:bootstrap:render": "node scripts/prisma-runner.mjs generate && node scripts/prisma-runner.mjs migrate deploy && node scripts/prisma-runner.mjs seed:safe",
    "db:studio": "node scripts/prisma-runner.mjs studio --schema prisma/schema.prisma",
    "db:dump": "node scripts/db-dump.mjs",
    "db:import:free-exercise-db": "tsx scripts/import-free-exercise-db.ts",
    "db:local:start": "docker compose -f docker-compose.dev-db.yml up -d",
    "db:local:stop": "docker compose -f docker-compose.dev-db.yml down",
    "db:local:reset": "npm run db:local:start && npm run db:push:emergency && npm run db:seed",
    "db:migrate:data": "node scripts/migrate-data.js",
    "db:export": "node scripts/migrate-data.js --export",
    "db:import": "node scripts/migrate-data.js --import",
    "db:sync": "node scripts/migrate-data.js --sync",
    "demo:reset": "tsx scripts/reset-demo.ts",
    "backfill:trainingexercise-exerciseid": "tsx scripts/backfill-trainingexercise-exerciseid.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "seed:demo": "tsx ../../scripts/seed-demo.ts",
    "test:route-parity": "tsx src/tests/routeParity.contract.test.ts",
    "db:bootstrap:ci": "CI=true node scripts/prisma-runner.mjs ci-bootstrap && node scripts/prisma-runner.mjs seed:safe && npm run db:import:free-exercise-db"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.7.0",
    "fastify-raw-body": "^5.0.0",
    "redis": "^4.7.0",
    "stripe": "^20.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.30",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}

# Local-only API overlay template
# Copy to `apps/api/.env.local` for local development.
# Keep production / hosted secrets in the deployment platform, not in git.

PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitsculpt_api_dev?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/fitsculpt_api_dev?schema=public
JWT_SECRET=replace-with-local-random-32-plus-chars
COOKIE_SECRET=replace-with-local-random-32-plus-chars
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
EMAIL_PROVIDER=console
ALLOW_SEED=0
AI_QUEUE_CONCURRENCY=2
AI_RATE_LIMIT_PER_MINUTE=100

# Optional local integrations
# REDIS_URL=redis://localhost:6379
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
# STRIPE_PRICE_STRENGTH_AI_MONTHLY=
# STRIPE_PRICE_NUTRI_AI_MONTHLY=
# UNSPLASH_ACCESS_KEY=
# NEON_DATABASE_URL=

# Local safety / maintenance toggles
# ALLOW_DB_RESET=1
# FORCE_SEED=1
# DB_PREFLIGHT_ON_BOOT=1
# SKIP_DB_PREFLIGHT=1

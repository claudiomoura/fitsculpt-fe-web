# ===========================================
# FitSculpt Environment Configuration
# ===========================================
#
# USO:
#   - .env.local        → Desarrollo local (PRIORIDAD ALTA)
#   - .env              → Produccion (Neon)
#   - .env.test         → Tests
#
# Para activar modo local, copia .env.local.example a .env.local
#
# ===========================================

# -------- LOCAL (desarrollo) --------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitsculpt_api_dev"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fitsculpt_api_dev"

# -------- NEON (produccion - comentario) --------
# DATABASE_URL="postgresql://neondb_owner:XXX@ep-xxx-pooler.xxx.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://neondb_owner:XXX@ep-xxx.xxx.aws.neon.tech/neondb?sslmode=require"

NODE_ENV=development
JWT_SECRET=local-dev-secret-1234567890
COOKIE_SECRET=local-dev-cookie-1234567890
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
EMAIL_PROVIDER=console
ALLOW_SEED=false

# -------- Redis (para BullMQ - opcional en local) --------
# REDIS_URL=redis://localhost:6379
# Descomenta arriba si tienes Redis local o quieres probar BullMQ

# -------- AI Queue --------
AI_QUEUE_CONCURRENCY=2
AI_RATE_LIMIT_PER_MINUTE=100


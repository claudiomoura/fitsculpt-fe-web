# API environment contract template (no real secrets)
# Local development should usually copy the needed values into `apps/api/.env.local`.

PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:5432/DBNAME?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST:5432/DBNAME?schema=public
JWT_SECRET=replace-with-32-plus-random-chars
COOKIE_SECRET=replace-with-32-plus-random-chars
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000

EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=replace-if-using-resend
VERIFICATION_TOKEN_TTL_HOURS=24
VERIFICATION_RESEND_COOLDOWN_MINUTES=10

ADMIN_EMAIL_SEED=admin@example.com
BOOTSTRAP_ADMIN_EMAILS=admin@example.com

GOOGLE_CLIENT_ID=replace-if-using-google-oauth
GOOGLE_CLIENT_SECRET=replace-if-using-google-oauth
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

OPENAI_API_KEY=replace-if-using-openai
OPENAI_KEY=replace-if-using-openai-legacy-alias
OPENAI_BASE_URL=https://api.openai.com/v1
AI_DAILY_LIMIT_FREE=3
AI_DAILY_LIMIT_PRO=30
AI_PRICING_JSON={"gpt-4o-mini":{"inputPer1M":15,"outputPer1M":60}}
PRO_MONTHLY_TOKENS=0

STRIPE_SECRET_KEY=replace-if-using-stripe
STRIPE_WEBHOOK_SECRET=replace-if-using-stripe
STRIPE_PRO_PRICE_ID=replace-if-using-stripe
STRIPE_PRICE_STRENGTH_AI_MONTHLY=replace-if-using-stripe
STRIPE_PRICE_NUTRI_AI_MONTHLY=replace-if-using-stripe

REDIS_URL=redis://localhost:6379
AI_QUEUE_CONCURRENCY=5
AI_RATE_LIMIT_PER_MINUTE=20

ALLOW_SEED=0
ALLOW_DB_RESET=0
FORCE_SEED=0
DB_PREFLIGHT_ON_BOOT=0
SKIP_DB_PREFLIGHT=0

DEMO_ADMIN_EMAIL=demo-admin@example.com
DEMO_ADMIN_PASSWORD=replace-for-local-seed-only
DEMO_GYM_NAME=Demo Gym
DEMO_GYM_CODE=DEMO01
DEMO_GYM_ACTIVATION_CODE=DEMO01-ACT
DEMO_MANAGER_EMAIL=demo.manager@fitsculpt.local
DEMO_MANAGER_PASSWORD=DemoManager123!
DEMO_MANAGER_NAME=Demo Manager
DEMO_TRAINER_EMAIL=demo.trainer@fitsculpt.local
DEMO_TRAINER_PASSWORD=DemoTrainer123!
DEMO_TRAINER_NAME=Demo Trainer
DEMO_MEMBER_1_EMAIL=demo.member1@fitsculpt.local
DEMO_MEMBER_1_PASSWORD=DemoMember123!
DEMO_MEMBER_1_NAME=Demo Member One
DEMO_MEMBER_2_EMAIL=demo.member2@fitsculpt.local
DEMO_MEMBER_2_PASSWORD=DemoMember123!
DEMO_MEMBER_2_NAME=Demo Member Two
DEMO_USER_EMAIL=demo.user@fitsculpt.local
DEMO_USER_PASSWORD=DemoUser123!
DEMO_USER_NAME=Demo User

UNSPLASH_ACCESS_KEY=replace-if-using-unsplash
NEON_DATABASE_URL=replace-if-using-migrate-data-script

# CI-only toggle used by db preflight tests / push flows
FS_CI_DB_MODE=push

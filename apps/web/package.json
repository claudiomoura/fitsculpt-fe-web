{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "pnpm lint && pnpm typecheck && pnpm test && pnpm e2e -- e2e/gym-nutrition-flow.spec.ts --reporter=line && pnpm build",
    "test:contracts": "vitest run src/test/aiGenerateGuardrail.contract.test.ts src/test/betaCriticalBff.contract.test.ts src/test/bffContractsRcV1.contract.test.ts",
    "e2e": "playwright test",
    "e2e:smoke:core": "playwright test e2e/core-loop.spec.ts",
    "e2e:smoke:token": "playwright test e2e/token-lifecycle.spec.ts",
    "e2e:smoke:beta": "node scripts/run-beta-smoke.mjs",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "lint:ds": "node scripts/lint-design-system-guardrails.mjs",
    "endpoints:inventory": "node scripts/endpoints-inventory.mjs",
    "endpoints:inventory:check": "node scripts/endpoints-inventory.mjs --check"
  },
  "dependencies": {
    "lucide-react": "file:vendor/lucide-react",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}

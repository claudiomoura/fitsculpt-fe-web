{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "pnpm lint && pnpm lint:ds:imports && pnpm typecheck && pnpm test && node scripts/run-beta-smoke.mjs && pnpm build",
    "test:contracts": "vitest run src/test/aiGenerateGuardrail.contract.test.ts src/test/betaCriticalBff.contract.test.ts src/test/bffContractsRcV1.contract.test.ts src/test/rcSurfaceContracts.contract.test.ts",
    "e2e": "playwright test",
    "e2e:smoke:core": "playwright test e2e/core-loop.spec.ts",
    "e2e:smoke:token": "playwright test e2e/token-lifecycle.spec.ts",
    "e2e:smoke:beta": "node scripts/run-beta-smoke.mjs",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "lint:ds": "node scripts/lint-design-system-guardrails.mjs",
    "lint:ds:imports": "node scripts/lint-design-system-imports.mjs",
    "endpoints:inventory": "node scripts/endpoints-inventory.mjs",
    "endpoints:inventory:check": "node scripts/endpoints-inventory.mjs --check",
    "mobile:android:sync": "npx cap sync android",
    "mobile:android:prepare": "npm run build && npm run mobile:android:sync",
    "mobile:android:doctor": "npx cap doctor"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@sentry/nextjs": "^10.46.0",
    "next": "16.1.1",
    "posthog-js": "^1.360.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
